# Database
DATABASE_URL=Host=localhost;Port=5432;Database=lodeluna;Username=postgres;Password=your_password

# JWT
JWT_SECRET=ChangeThisToASecureRandomStringAtLeast32Characters!
JWT_ISSUER=lodeluna-api
JWT_AUDIENCE=lodeluna-app
JWT_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7

# Email (Brevo)
BREVO_API_KEY=xkeysib-your-api-key-here
EMAIL_FROM=your-verified-email@gmail.com
EMAIL_FROM_NAME=

# Storage
STORAGE_PATH=./storage
MAX_IMAGE_SIZE_MB=2

# App
FRONTEND_URL=http://localhost:4200
ENVIRONMENT=development
